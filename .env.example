# Environment configuration
# Precedence (identical for `next dev/build` and all CLI scripts via src/scripts/cli):
#   1. real environment variables (Coolify / CI) — always win, never overridden by files
#   2. .env.local  (local secrets — gitignored)
#   3. .env.development / .env.production (by NODE_ENV)
#   4. .env

# Database (provided by Coolify in production)
DATABASE_URI=postgres://user:password@localhost:5432/liderconstruct

# Payload
PAYLOAD_SECRET=change-me-to-a-long-random-string

# Public site URL (used for SEO canonical, Open Graph, sitemap)
NEXT_PUBLIC_SERVER_URL=https://liderconstruct.md

# Transactional email (Postmark / SES SMTP — per infra design)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM_NAME=LiderConstruct
EMAIL_FROM_ADDRESS=comenzi@liderconstruct.md
ORDER_NOTIFICATION_TO=comenzi@liderconstruct.md

# Contact (shown in the header/floating bar)
NEXT_PUBLIC_CONTACT_PHONE=+373 22 000 000
NEXT_PUBLIC_CONTACT_EMAIL=info@liderconstruct.md
